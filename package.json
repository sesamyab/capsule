{
  "name": "capsule-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Capsule - Open standard for secure article encryption using envelope encryption",
  "scripts": {
    "dev": "pnpm --filter capsule-demo dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec rm -rf node_modules dist .next && rm -rf node_modules",
    "demo": "pnpm --filter capsule-demo",
    "client": "pnpm --filter @sesamy/capsule"
  },
  "keywords": [
    "encryption",
    "envelope-encryption",
    "capsule",
    "web-crypto",
    "rsa",
    "aes-gcm"
  ],
  "author": "Capsule Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
