---
/**
 * Article Page - Demonstrates clean Capsule HTML output
 * 
 * Uses the @sesamy/capsule client for decryption with the high-level API.
 * 
 * View Page Source to see:
 * - Well-formatted HTML structure
 * - Encrypted data in data-capsule attribute (JSON)
 * - Standard HTML elements for the Capsule client
 */

import Layout from "../../layouts/Layout.astro";
import { getArticle } from "../../lib/articles";
import { encryptArticleContent } from "../../lib/encryption";

// Get article from URL
const { slug } = Astro.params;
const article = getArticle(slug!);

if (!article) {
  return Astro.redirect("/404");
}

// Pre-encrypt the content server-side (now async)
const encryptedData = await encryptArticleContent(
  article.id,
  article.premiumContent,
  "premium"
);
---

<Layout title={`${article.title} - Capsule Demo`}>
  <!-- 
  ============================================================
  CAPSULE ENCRYPTED ARTICLE
  ============================================================
  This page demonstrates the Capsule encryption standard.
  
  Uses @sesamy/capsule client with high-level API:
  - Auto key generation (RSA-2048)
  - Automatic DEK caching and renewal
  - Script execution in decrypted content
  - Custom events for unlock lifecycle
  
  View source to see the clean HTML structure!
  ============================================================
  -->

  <main class="article-page">
    <article data-capsule-article={article.id}>
      
      <!-- Article Header (always visible) -->
      <header class="article-header">
        <h1>{article.title}</h1>
        <div class="article-meta">
          <span>By {article.author}</span>
          <span>•</span>
          <time datetime={article.publishedAt}>
            {new Date(article.publishedAt).toLocaleDateString("en-US", {
              year: "numeric",
              month: "long", 
              day: "numeric",
            })}
          </time>
        </div>
      </header>

      <!-- Preview Content (free, visible to all) -->
      <section class="preview-content">
        {article.previewContent.split("\n\n").map((p) => (
          <p>{p}</p>
        ))}
      </section>

      <!-- 
      ============================================================
      CAPSULE ENCRYPTED CONTENT
      ============================================================
      The data-capsule attribute contains the encrypted article in JSON:
      - articleId: Unique identifier
      - encryptedContent: AES-256-GCM ciphertext (Base64)
      - iv: Initialization vector (Base64)
      - wrappedKeys: Array of wrapped DEKs for different access tiers
      
      The @sesamy/capsule client will:
      1. Find this element by data-capsule attribute
      2. Parse the encrypted data
      3. Call the unlock function to get the DEK
      4. Decrypt and render the content
      5. Execute any embedded scripts
      6. Emit 'capsule:unlock' event
      ============================================================
      -->
      <section 
        class="encrypted-section" 
        id={`capsule-${article.id}`}
        data-capsule={JSON.stringify(encryptedData)}
        data-capsule-id={article.id}
      >
        <!-- Locked State (shown before decryption) -->
        <div class="locked-overlay" id="locked-state">
          <div class="lock-icon">🔐</div>
          <h3>Premium Content</h3>
          <p>This content is encrypted. Unlock to read.</p>
          <button class="unlock-button" id="unlock-btn">
            Unlock Article
          </button>
        </div>
      </section>

    </article>
  </main>

  <!-- 
  ============================================================
  CAPSULE CLIENT INITIALIZATION
  ============================================================
  Using the @sesamy/capsule high-level API:
  - Automatic key pair management
  - Built-in DEK caching
  - Event-based notifications
  ============================================================
  -->
  <script>
    import { CapsuleClient } from '@sesamy/capsule';
    import type { UnlockFunction } from '@sesamy/capsule';

    // Console logging helper
    function log(message: string, type = 'info') {
      const body = document.getElementById('console-body');
      if (body) {
        const line = document.createElement('div');
        line.className = `console-line ${type}`;
        line.textContent = `[${new Date().toLocaleTimeString()}] ${message}`;
        body.appendChild(line);
        body.scrollTop = body.scrollHeight;
      }
      console.log(`[Capsule] ${message}`);
    }

    // Unlock function - called by the client to fetch encrypted DEK
    const unlock: UnlockFunction = async ({ keyId, wrappedDek, publicKey, articleId }) => {
      log(`Requesting DEK for ${keyId}...`, 'info');
      
      const response = await fetch('/api/unlock', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ keyId, wrappedDek, publicKey, articleId }),
      });

      if (!response.ok) {
        const error = await response.json();
        throw new Error(error.error || `Server returned ${response.status}`);
      }

      const data = await response.json();
      log(`Received encrypted DEK (expires: ${data.expiresAt})`, 'success');
      return data;
    };

    // Initialize the Capsule client
    const capsule = new CapsuleClient({
      unlock,
      executeScripts: true,
      dekStorage: 'persist',
      logger: (msg, level) => log(msg, level === 'error' ? 'error' : level === 'debug' ? 'crypto' : 'info'),
    });

    // Get article ID from the encrypted section
    const encryptedSection = document.querySelector('[data-capsule]') as HTMLElement;
    const articleId = encryptedSection?.dataset.capsuleId;

    // Listen for unlock events
    document.addEventListener('capsule:unlock', (e: Event) => {
      const detail = (e as CustomEvent).detail;
      log(`✨ Content unlocked using ${detail.keyId}!`, 'success');
      
      // Update UI
      const section = document.querySelector('.encrypted-section');
      section?.classList.add('unlocked');
      
      // Add unlock banner
      const banner = document.createElement('div');
      banner.className = 'unlock-banner';
      banner.innerHTML = '✓ Premium Content Unlocked';
      section?.insertBefore(banner, section.firstChild);
      
      // Hide locked state
      const lockedState = document.getElementById('locked-state');
      if (lockedState) lockedState.style.display = 'none';
    });

    document.addEventListener('capsule:error', (e: Event) => {
      const detail = (e as CustomEvent).detail;
      log(`Error: ${detail.error.message}`, 'error');
      
      const btn = document.getElementById('unlock-btn') as HTMLButtonElement;
      if (btn) {
        btn.disabled = false;
        btn.textContent = 'Retry';
      }
    });

    document.addEventListener('capsule:state', (e: Event) => {
      const detail = (e as CustomEvent).detail;
      log(`State: ${detail.previousState} → ${detail.state}`, 'info');
    });

    // Handle unlock button click
    const unlockBtn = document.getElementById('unlock-btn');
    unlockBtn?.addEventListener('click', async () => {
      const btn = unlockBtn as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Unlocking...';

      try {
        if (articleId) {
          await capsule.unlockElement(articleId);
        }
      } catch (error) {
        // Error event will handle UI update
        console.error('Unlock failed:', error);
      }
    });

    // Log on page load
    log('Capsule client initialized. Click "Unlock Article" to decrypt.', 'info');
    log(`Article ID: ${articleId}`, 'info');
  </script>
</Layout>
