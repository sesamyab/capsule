---
/**
 * Article Page - DCA Encrypted Content
 *
 * Uses the DCA publisher for server-side encryption and DcaClient for
 * client-side decryption.
 *
 * View Page Source to see:
 * - script.dca-manifest with signed JWT, wrapped keys, and AES-256-GCM ciphertext
 */

import Layout from "../../layouts/Layout.astro";
import { getArticle } from "../../lib/articles";
import { renderDcaArticle, DEMO_ISSUER_NAME } from "../../lib/encryption";

// Get article from URL
const { slug } = Astro.params;
const article = getArticle(slug!);

if (!article) {
  return Astro.redirect("/404");
}

// Pre-encrypt the content server-side using DCA publisher
const dcaResult = await renderDcaArticle(article.id);
const contentName = "bodytext";
---

<Layout title={`${article.title} - DCA Demo`}>
  <!-- 
  ============================================================
  DCA ENCRYPTED ARTICLE
  ============================================================
  This page demonstrates the DCA (Delegated Content Access) standard.
  
  Uses @sesamy/capsule DcaClient:
  - Parses the dca-manifest script from the DOM
  - Calls issuer /api/unlock endpoint to get wrapKeys
  - Decrypts content locally with AES-256-GCM + AAD
  
  View source to see the clean DCA HTML structure!
  ============================================================
  -->

  <!-- DCA manifest embedded by publisher -->
  {dcaResult && (
    <Fragment set:html={dcaResult.result.html.manifestScript} />
  )}

  <main class="article-page">
    <article>
      
      <!-- Article Header (always visible) -->
      <header class="article-header">
        <h1>{article.title}</h1>
        <div class="article-meta">
          <span>By {article.author}</span>
          <span>•</span>
          <time datetime={article.publishedAt}>
            {new Date(article.publishedAt).toLocaleDateString("en-US", {
              year: "numeric",
              month: "long", 
              day: "numeric",
            })}
          </time>
        </div>
      </header>

      <!-- Preview Content (free, visible to all) -->
      <section class="preview-content">
        {article.previewContent.split("\n\n").map((p) => (
          <p>{p}</p>
        ))}
      </section>

      <!-- Encrypted content section -->
      <section class="encrypted-section" id={`dca-${article.id}`}>
        <div class="locked-overlay" id="locked-state">
          <div class="lock-icon">🔐</div>
          <h3>Premium Content</h3>
          <p>This content is encrypted with DCA. Unlock to read.</p>
          <button class="unlock-button" id="unlock-btn">
            Unlock Article
          </button>
        </div>
      </section>

    </article>
  </main>

  <!-- DCA Client Initialization -->
  <script define:vars={{ issuerName: DEMO_ISSUER_NAME, contentName }}>
    // Inline the issuerName and contentName from server
    window.__DCA_ISSUER_NAME__ = issuerName;
    window.__DCA_CONTENT_NAME__ = contentName;
  </script>
  <script>
    import { DcaClient } from '@sesamy/capsule';

    function log(message: string, type = 'info') {
      const body = document.getElementById('console-body');
      if (body) {
        const line = document.createElement('div');
        line.className = `console-line ${type}`;
        line.textContent = `[${new Date().toLocaleTimeString()}] ${message}`;
        body.appendChild(line);
        body.scrollTop = body.scrollHeight;
      }
      console.log(`[DCA] ${message}`);
    }

    const issuerName = (window as any).__DCA_ISSUER_NAME__ || 'sesamy-astro-demo';
    const dcaContentName = (window as any).__DCA_CONTENT_NAME__ || 'bodytext';
    const client = new DcaClient();

    log('DCA client initialized', 'info');

    // Parse the DCA manifest from the page
    let page: ReturnType<typeof client.parsePage> | null = null;
    try {
      page = client.parsePage();
      const contentNames = Object.keys(page.manifest.content);
      log(`Found DCA manifest: ${contentNames.length} content item(s)`, 'info');
    } catch (e) {
      log('No DCA manifest found on page', 'error');
    }

    const unlockBtn = document.getElementById('unlock-btn');
    unlockBtn?.addEventListener('click', async () => {
      if (!page) return;

      const btn = unlockBtn as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Unlocking...';

      try {
        log(`Requesting keys from issuer "${issuerName}"...`, 'info');
        const keys = await client.unlock(page, issuerName);
        log('Keys received, decrypting...', 'success');

        const html = await client.decrypt(page, dcaContentName, keys);
        log(`Content decrypted (${html.length} chars)`, 'success');

        // Replace locked state with decrypted content
        const section = document.querySelector('.encrypted-section');
        if (section) {
          section.classList.add('unlocked');
          const lockedState = document.getElementById('locked-state');
          if (lockedState) lockedState.style.display = 'none';

          const banner = document.createElement('div');
          banner.className = 'unlock-banner';
          banner.innerHTML = '🔓 Content decrypted via DCA';
          section.insertBefore(banner, section.firstChild);

          const content = document.createElement('div');
          content.className = 'premium-content';
          content.innerHTML = html;
          section.appendChild(content);
        }

        log('✨ Article unlocked!', 'success');
      } catch (error) {
        const msg = error instanceof Error ? error.message : 'Unlock failed';
        log(`Error: ${msg}`, 'error');
        btn.disabled = false;
        btn.textContent = 'Retry';
      }
    });

    log('Click "Unlock Article" to decrypt.', 'info');
  </script>
</Layout>
