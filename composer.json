{
    "name": "sesamy/capsule-publisher",
    "description": "PHP port of the Capsule (DCA) CMS publisher. Encrypts content, derives wrap keys, wraps for issuers (ECDH-P256 / RSA-OAEP), and signs ES256 resource JWTs.",
    "type": "library",
    "license": "MIT",
    "keywords": ["capsule", "dca", "encryption", "publisher", "wordpress", "cms"],
    "homepage": "https://github.com/sesamyab/capsule/tree/main/packages/capsule-publisher-php",
    "support": {
        "issues": "https://github.com/sesamyab/capsule/issues",
        "source": "https://github.com/sesamyab/capsule"
    },
    "authors": [
        {
            "name": "Sesamy",
            "homepage": "https://sesamy.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-openssl": "*",
        "ext-json": "*",
        "ext-hash": "*",
        "phpseclib/phpseclib": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Sesamy\\Capsule\\Publisher\\": "packages/capsule-publisher-php/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sesamy\\Capsule\\Publisher\\Tests\\": "packages/capsule-publisher-php/tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit -c packages/capsule-publisher-php/phpunit.xml.dist",
        "test:interop": "packages/capsule-publisher-php/scripts/run-interop.sh"
    }
}
